# ── Generated Moon — Environment Variables ──────────────────────────────────

# Copy this file to server/.env and fill in your values

# HuggingFace Inference API (free tier)
# Get your token from: https://huggingface.co/settings/tokens
# Free account is enough — just needs read access
HF_API_KEY=hf_...
# Model to use — free & no approval needed:
#   mistralai/Mistral-7B-Instruct-v0.3  (default, recommended)
#   HuggingFaceH4/zephyr-7b-beta
#   microsoft/Phi-3-mini-4k-instruct
HF_MODEL=mistralai/Mistral-7B-Instruct-v0.3

# Stripe Payments
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Email (Resend)
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_...
EMAIL_TO=moonravendigital@gmail.com
EMAIL_FROM=noreply@generatedmoon.com

# Calendly
CALENDLY_LINK=https://calendly.com/generatedmoon

# Server
PORT=3001
CLIENT_URL=http://localhost:5173
