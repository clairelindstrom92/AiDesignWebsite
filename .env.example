# ── Luxury AI Designs — Environment Variables ────────────────────────────────

# Copy this file to server/.env and fill in your values
# In production, set these in your Railway dashboard (not in a file)

# HuggingFace Inference API (free tier)
# Get your token from: https://huggingface.co/settings/tokens
HF_API_KEY=hf_...
# Confirmed working free model (no license gate):
HF_MODEL=meta-llama/Llama-3.1-8B-Instruct:cerebras

# Stripe Payments (optional — skip until ready)
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Email (Resend — optional)
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_...
EMAIL_TO=moonravendigital@gmail.com
EMAIL_FROM=noreply@generatedmoon.com

# Calendly
CALENDLY_LINK=https://calendly.com/generatedmoon

# Server
PORT=3001
# In production (Railway), set CLIENT_URL to your Vercel domain:
# CLIENT_URL=https://your-project.vercel.app
CLIENT_URL=http://localhost:5173
